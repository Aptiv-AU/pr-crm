// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String    @id @default(cuid())
  name          String
  logo          String?
  currency      String    @default("AUD")
  contactEmail  String?
  primaryColour String?
  aiProvider    String?
  aiModel       String?
  createdAt     DateTime  @default(now())
  users         User[]
  clients       Client[]
  contacts      Contact[]
  suppliers     Supplier[]
  campaigns     Campaign[]
  coverages     Coverage[]
  interactions  Interaction[]
  contactTags     ContactTag[]
  contactSegments ContactSegment[]
  emailTemplates  EmailTemplate[]
  suppressions    Suppression[]
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  role           String        @default("owner")
  emailVerified  DateTime?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  accounts       Account[]
  sessions       Session[]
  emailAccounts  EmailAccount[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  industry       String
  colour         String
  bgColour       String
  initials       String
  logo           String?
  archivedAt     DateTime?
  currency       String?
  slug           String
  createdAt      DateTime     @default(now())
  campaigns      Campaign[]
  contacts       ClientContact[]

  @@unique([organizationId, slug])
  @@index([archivedAt])
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

model Contact {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id])
  name             String
  email            String?
  phone            String?
  outlet           String?
  beat             String?
  tier             String?
  kind             String            @default("journalist")
  health           String            @default("warm")
  initials         String
  avatarBg         String
  avatarFg         String
  photo            String?
  instagram        String?
  twitter          String?
  linkedin         String?
  notes            String?
  slug             String
  createdAt        DateTime          @default(now())
  campaignContacts CampaignContact[]
  outreaches       Outreach[]
  coverages        Coverage[]
  interactions     Interaction[]
  tags             ContactTagAssignment[]

  @@unique([organizationId, slug])
  @@index([organizationId, createdAt])
  @@index([organizationId, beat])
  @@index([organizationId, tier])
  @@index([organizationId, outlet])
  @@index([organizationId, email])
}

model ContactTag {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  label          String
  colorBg        String   @default("#374151")
  colorFg        String   @default("#ffffff")
  createdAt      DateTime @default(now())
  assignments    ContactTagAssignment[]

  @@unique([organizationId, label])
}

model ContactTagAssignment {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       ContactTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([contactId, tagId])
  @@index([tagId])
}

model ContactSegment {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  filter         Json
  createdAt      DateTime @default(now())

  @@unique([organizationId, name])
}

model Supplier {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id])
  name              String
  serviceCategory   String
  email             String?
  phone             String?
  website           String?
  notes             String?
  rating            Int?
  slug              String
  createdAt         DateTime           @default(now())
  contacts          SupplierContact[]
  campaignSuppliers CampaignSupplier[]
  budgetLineItems   BudgetLineItem[]

  @@unique([organizationId, slug])
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String
  role       String?
  email      String?
  phone      String?
  notes      String?
}

model Campaign {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id])
  clientId          String
  client            Client             @relation(fields: [clientId], references: [id])
  name              String
  type              String
  status            CampaignStatus     @default(draft)
  currentPhase      String?
  budget            Decimal?
  startDate         DateTime?
  dueDate           DateTime?
  brief             String?
  archivedAt        DateTime?
  slug              String
  createdAt         DateTime           @default(now())
  phases            CampaignPhase[]
  campaignContacts  CampaignContact[]
  campaignSuppliers CampaignSupplier[]
  budgetLineItems   BudgetLineItem[]
  outreaches        Outreach[]
  coverages         Coverage[]
  interactions      Interaction[]
  eventDetail       EventDetail?

  @@unique([organizationId, slug])
  @@index([archivedAt])
}

model CampaignPhase {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  status     PhaseStatus @default(pending)
}

model BudgetLineItem {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal
  confirmed   Boolean   @default(false)
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
}

model CampaignContact {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id])
  status     String   @default("added")

  @@unique([campaignId, contactId])
  @@index([contactId])
}

model CampaignSupplier {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  role       String
  agreedCost Decimal?
  status     SupplierStatus @default(pending)

  @@unique([campaignId, supplierId])
}

model Outreach {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id])
  subject       String
  body          String
  status        OutreachStatus @default(draft)
  generatedByAI  Boolean   @default(false)
  followUpNumber Int       @default(0)
  scheduledAt    DateTime?
  sentVia        String?
  messageId      String?
  threadId      String?
  sentAt         DateTime?
  lastCheckedForReplyAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([campaignId, status])
  @@index([campaignId, contactId, followUpNumber])
}

model Coverage {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  campaignId     String?
  campaign       Campaign?     @relation(fields: [campaignId], references: [id])
  contactId      String?
  contact        Contact?      @relation(fields: [contactId], references: [id])
  publication    String
  date           DateTime
  type           String
  url            String?
  mediaValue     Decimal?
  attachmentUrl  String?
  notes          String?
  slug           String
  createdAt      DateTime      @default(now())

  @@unique([organizationId, slug])
  @@index([organizationId, date])
  @@index([campaignId, date])
  @@index([contactId])
}

model Interaction {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id])
  type           String
  date           DateTime
  summary        String?
  campaignId     String?
  campaign       Campaign?    @relation(fields: [campaignId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([contactId, date])
  @@index([organizationId, date])
}

model EventDetail {
  id              String          @id @default(cuid())
  campaignId      String          @unique
  campaign        Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  venue           String?
  eventDate       DateTime?
  eventTime       String?
  guestCount      Int?
  runsheetEntries RunsheetEntry[]
}

model RunsheetEntry {
  id            String      @id @default(cuid())
  eventDetailId String
  eventDetail   EventDetail @relation(fields: [eventDetailId], references: [id], onDelete: Cascade)
  time          String
  endTime       String?
  activity      String
  assignee      String?
  location      String?
  notes         String?
  order         Int
}

model EmailAccount {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String           @default("microsoft")
  email           String
  accessToken     String           @db.Text
  refreshToken    String           @db.Text
  expiresAt       DateTime
  signatureHtml   String?          @db.Text
  signatureSource SignatureSource?
  fontFamily      String?
  fontSize        String?
  styleResolvedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
}

enum SignatureSource {
  api
  scraped
  manual
  default
}

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  subject        String
  body           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, name])
}

model Suppression {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String
  reason         SuppressionReason
  note           String?
  createdByUserId String?
  createdAt      DateTime @default(now())

  @@unique([organizationId, email])
}

enum SuppressionReason {
  reply_request
  bounce
  manual
}

enum CampaignStatus {
  draft
  active
  complete
}

enum OutreachStatus {
  draft
  approved
  sent
  replied
}

enum PhaseStatus {
  pending
  active
  complete
}

enum SupplierStatus {
  pending
  confirmed
  cancelled
}
