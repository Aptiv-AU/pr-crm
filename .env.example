# Database
DATABASE_URL=

# AI providers (at least one recommended)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=

# Vercel Blob (for uploads)
BLOB_READ_WRITE_TOKEN=

# Microsoft Graph (Outlook send provider)
# Redirect URI: <APP_URL>/api/email/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Google (Gmail send provider)
# Redirect URI: <APP_URL>/api/email/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron
CRON_SECRET=

# App URL (used for OAuth redirect URIs)
NEXTAUTH_URL=
